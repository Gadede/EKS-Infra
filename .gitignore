# Local Terraform state (we use S3 backend instead, but ignore just in case)
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Local .terraform directory (downloaded providers/modules, regenerated by init)
.terraform/

# Variable files that might contain sensitive overrides
*.tfvars
*.tfvars.json

# Terraform crash logs
crash.log
crash.*.log

# OS/editor files
.DS_Store